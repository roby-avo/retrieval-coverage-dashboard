POSTGRES_DB=coverage_dashboard
POSTGRES_PORT=5432

API_PORT=8000
WEB_PORT=5173
ADMINER_PORT=8082

# Optional: enables live retrieval attempts and web-launched experiments.
ALPACA_TOKEN=
ALPACA_AUTH_TOKEN=
ALPACA_TOKEN_AUTH=
ALPACA_METADATA_URL=https://alpaca.zooverse.dev/debug/elasticsearch/alpaca-entities/_search
ALPACA_SEARCH_ENDPOINT=https://alpaca.zooverse.dev/debug/elasticsearch/alpaca-entities/_search

# Optional: enables LLM query-plan generation for web-launched experiments.
# These generic values are also configurable from the Settings tab.
LLM_PROVIDER=openrouter
LLM_PROVIDER_NAME=Cerebras
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
LLM_MAX_TOKENS=

# Backward-compatible OpenRouter aliases.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_PROVIDER=Cerebras
OPENROUTER_MAX_TOKENS=
